# any2agent — environment template. Copy to `.env` and fill in the keys you have.
#   cp .env.example .env
# A model appears in the picker only when its provider key is set. Leave the
# rest blank. Never commit `.env` (it is gitignored).

# ── LLM providers (set at least one) ────────────────────────
OPENAI_API_KEY=
MOONSHOT_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Optional model id overrides (defaults used if blank) ────
# OPENAI_MODEL=
# KIMI_MODEL=
# CLAUDE_MODEL=
# GEMINI_MODEL=
# DEFAULT_MODEL_ID=        # gpt | kimi | claude | gemini

# ── Optional: credential for the TARGET system (passthrough usually
#    carries the end-user's own session, so this is rarely needed) ──
# Set the env var named by <project>.any2agent.toml [auth].token_env, e.g.:
# MYAPP_TOKEN=
