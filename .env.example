# any2agent — environment template. Copy to `.env` and fill in the keys you have.
#   cp .env.example .env
# A model appears in the picker only when its provider key is set. Leave the
# rest blank. Never commit `.env` (it is gitignored).

# ── Major LLM platforms (set at least one) — all routed via LiteLLM ──
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
MOONSHOT_API_KEY=
COHERE_API_KEY=
PERPLEXITYAI_API_KEY=
TOGETHERAI_API_KEY=
OPENROUTER_API_KEY=
# OLLAMA_HOST=http://localhost:11434     # local models (no API key)

# ── Optional model id overrides (defaults used if blank) ──
# OPENAI_MODEL= / CLAUDE_MODEL= / GEMINI_MODEL= / MISTRAL_MODEL= / GROQ_MODEL=
# DEEPSEEK_MODEL= / XAI_MODEL= / KIMI_MODEL= / COHERE_MODEL= / PERPLEXITY_MODEL=
# TOGETHER_MODEL= / OPENROUTER_MODEL= / OLLAMA_MODEL=
# DEFAULT_MODEL_ID=        # which provider id the picker selects first

# ── Anything else LiteLLM supports (Azure / Bedrock / Vertex / custom) ──
#   comma-separated raw LiteLLM model strings; their own creds are read from env.
# ANY2AGENT_MODELS=azure/my-deploy, bedrock/anthropic.claude-3-5-sonnet-20241022-v2:0

# ── Optional: credential for the TARGET system (passthrough usually
#    carries the end-user's own session, so this is rarely needed) ──
# Set the env var named by <project>.any2agent.toml [auth].token_env, e.g.:
# MYAPP_TOKEN=
